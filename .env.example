# ─── Gemini AI ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Tistory ────────────────────────────────────────────────────────────────
TISTORY_BLOG_NAME=your_blog_name          # 기본(폴백) 블로그 ID — myblog.tistory.com → myblog
TISTORY_CATEGORY=                         # 카테고리명 (선택)
# 역할별 블로그 ID — 파이프라인이 각자 매핑된 블로그에 발행한다.
# 단일 블로그만 운영한다면 모두 비워두면 TISTORY_BLOG_NAME 으로 폴백된다.
TISTORY_BLOG_REALESTATE=                  # 분양정보용 블로그 ID
TISTORY_BLOG_RISESET=                     # 일출일몰용 블로그 ID
TISTORY_BLOG_NEWSPICK=                    # 뉴스픽용 블로그 ID
TISTORY_BLOG_POLICY=                      # 정책정보용 블로그 ID
TISTORY_BLOG_RESERVED=                    # 예약 슬롯 (선택)
TISTORY_BLOG_BACKLINK=                    # 백링크 소스 블로그 ID
TISTORY_BLOG_ALIEXPRESS=                  # 알리익스프레스 상품글 블로그 ID

# ─── WordPress ──────────────────────────────────────────────────────────────
WP_SITE_URL=https://your-site.com
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx       # WordPress Application Password
WP_JWT_TOKEN=your_jwt_token_here          # JWT Authentication 플러그인 토큰
WP_CATEGORY_ID=1                          # 발행 카테고리 ID
WP_TAG_ID=1                               # 발행 태그 ID
WP_CATEGORY=                              # 카테고리명 (선택)

# ─── Naver ──────────────────────────────────────────────────────────────────
NAVER_USERNAME=your_naver_id
NAVER_PASSWORD=your_naver_password
NAVER_BLOG_ID=your_blog_id
NAVER_CAFE_ID=your_cafe_url_id
NAVER_CAFE_MENU_ID=                       # 게시판 ID (선택)
NAVER_CLIENT_ID=your_naver_api_client_id  # DataLab API용
NAVER_CLIENT_SECRET=your_naver_api_secret

# ─── Coupang Partners ───────────────────────────────────────────────────────
COUPANG_ACCESS_KEY=your_coupang_access_key
COUPANG_SECRET_KEY=your_coupang_secret_key
COUPANG_AF_CODE=AF0000000
COUPANG_CHANNEL_ID=                       # 기본 채널(파이프라인별 오버라이드 없을 때)
COUPANG_FAKE_LINK=https://link.coupang.com/a/xxxxxx
COUPANG_PRODUCT_COUNT=3
# 파이프라인별 쿠팡 파트너스 채널 ID (없으면 COUPANG_CHANNEL_ID 사용)
# 본인이 쿠팡 파트너스 대시보드에서 생성한 채널 ID 를 입력하세요.
COUPANG_CHANNEL_ID_WP=                    # WordPress 채널
COUPANG_CHANNEL_ID_GITHUB=                # GitHub Pages — 비우면 repo 이름으로 자동 감지
COUPANG_CHANNEL_ID_PINTEREST=             # Pinterest 채널
COUPANG_CHANNEL_ID_NAVERBLOG=             # 네이버 블로그 채널
COUPANG_CHANNEL_ID_NAVERCAFE=             # 네이버 카페 채널
COUPANG_CHANNEL_ID_THREADS=               # Threads 채널
COUPANG_CHANNEL_ID_TWITTER=               # Twitter 채널

# ─── Newspick ───────────────────────────────────────────────────────────────
NEWSPICK_REFERRAL=your_referral_code      # 뉴스픽 추천인 코드 (선택)
NEWSPICK_CATEGORY=추천                    # 추천|유머|사연|웹툰|뷰티|건강|음식|여행|스포츠|연예|경제|IT

# ─── ItemScout ──────────────────────────────────────────────────────────────
ITEMSCOUT_API_KEY=your_itemscout_api_key

# ─── 공공데이터포털 ──────────────────────────────────────────────────────────
DATA_GO_KR_KEY=your_data_go_kr_service_key

# ─── 파이프라인 설정 ─────────────────────────────────────────────────────────
POST_COUNT=3                              # 1회 실행당 발행 글 수
BLOG_TARGET=tistory                       # tistory | naver
NAVER_TARGET=blog                         # blog | cafe
SNS_TARGETS=twitter,threads               # 콤마 구분
REALESTATE_REGIONS=서울_강남구,서울_서초구
USED_KEYWORDS_TTL_DAYS=90                 # 미사용 N일 후 자동 재활성화 (0=영구)

# ─── 백링크 파이프라인 ───────────────────────────────────────────────────────
# 자체 블로그 URL 을 수집해 SNS 에 반복 노출(백링크)하는 파이프라인
BACKLINK_SITES=https://your-site1.com,https://your-site2.com
BACKLINK_TARGETS=twitter,threads          # 발행 플랫폼
BACKLINK_COUNT=3                          # 1회 실행당 플랫폼별 발행 수
BACKLINK_THROTTLE=300                     # 발행 사이 대기(초) — X 계정 잠김 방지
BACKLINK_STRATEGIES=jetpack,rest          # jetpack|yoast|wp_core|rest
BACKLINK_MESSAGE_PREFIX=오늘의 정보

# ─── 스케줄러 (시간은 HH:MM 형식, 여러 개는 콤마 구분) ─────────────────────
SCHEDULE_NEWSPICK_TISTORY=09:00,18:00
SCHEDULE_NEWSPICK_WP=10:00,19:00
SCHEDULE_NEWSPICK_NAVER=11:00
SCHEDULE_NEWSPICK_SNS=08:00,20:00
SCHEDULE_COUPANG_WP=07:00
SCHEDULE_REALESTATE=06:00
SCHEDULE_BACKLINK_SNS=13:00,21:00         # 백링크 → SNS
SCHEDULE_RISESET_TISTORY=06:40            # 일출일몰 → 티스토리
SCHEDULE_POLICY_TISTORY=12:00,22:00       # 정책뉴스 → 티스토리
SCHEDULE_ALIEXPRESS_WP=11:30              # 알리익스프레스 → WordPress (전체 프로필)
SCHEDULE_ALIEXPRESS_TISTORY=12:30         # 알리익스프레스 → 티스토리
SCHEDULE_ALIEXPRESS_THREADS=14:30         # 알리익스프레스 → Threads (single/chain)
SCHEDULE_ALIEXPRESS_NAVER_BLOG=13:30      # 알리익스프레스 → 네이버 블로그

# ─── AliExpress Partners ───────────────────────────────────────────────────
ALIEXPRESS_EMAIL=your_ali_email
ALIEXPRESS_PASSWORD=your_ali_password
ALIEXPRESS_TRACKING_ID=wordpress          # portals.aliexpress.com 트래킹 ID
ALIEXPRESS_HEADLESS=false                 # 첫 로그인은 수동(캡차) 대응
ALIEXPRESS_LOGIN_WAIT=180                 # 로그인 수동 대기 시간(초)
ALIEXPRESS_POST_COUNT=3                   # 1회 실행당 키워드/발행 수
ALIEXPRESS_PRODUCT_COUNT=10               # 1글당 상품 수

# ─── 정책 파이프라인 ────────────────────────────────────────────────────────
POLICY_FEEDS=정책뉴스,보도자료,이슈인사이트  # korea.kr RSS 피드명 콤마 구분
POLICY_POST_COUNT=3                        # 1회 실행당 발행 수

# ─── Telegram 알림 봇 ───────────────────────────────────────────────────────
# @BotFather 에서 본인 봇을 생성하고 토큰을 발급받으세요. 파이프라인 성공/실패 알림 전용.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id   # /start 후 api.telegram.org/bot{TOKEN}/getUpdates 로 확인

# ─── Kakao Developers ───────────────────────────────────────────────────────
KAKAO_APP_ID=your_kakao_app_id
KAKAO_NATIVE_APP_KEY=your_kakao_native_app_key
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_JAVASCRIPT_KEY=your_kakao_javascript_key
KAKAO_ADMIN_KEY=your_kakao_admin_key
# JS SDK 허용 도메인 (플랫폼 키 > JavaScript 키 > JS SDK 도메인 등록 목록)
# https://your-site.com
# http://localhost:3000

# 카카오톡 나와의 채팅 알림 (scripts/kakao_auth.py 로 초기 발급)
# access_token: 6시간 유효, 자동 갱신됨
# refresh_token: 최대 60일, 만료 전 재로그인 필요
KAKAO_ACCESS_TOKEN=
KAKAO_REFRESH_TOKEN=
